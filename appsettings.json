{
  "DatabaseSettings": {
    "DatabasePath": "../data/doit.db"
  },
  "JwtSettings": {
    "Issuer": "DoIt",
    "Audience": "DoIt",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 365
  },
  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174"
    ]
  },
  "DoItSettings": {
    "DefaultLocale": "es",
    "DefaultTheme": "system"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
